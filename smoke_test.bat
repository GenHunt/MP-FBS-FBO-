@echo off
chcp 65001 >nul 2>&1
setlocal enabledelayedexpansion

:: =============================================================================
:: smoke_test.bat — предварительная проверка перед сборкой EXE
::
:: Запустите этот скрипт ПЕРЕД build_exe.bat чтобы убедиться,
:: что приложение корректно работает в режиме без GUI.
::
:: Что проверяет:
::   1. Синтаксис всех .py-файлов (python -m compileall)
::   2. Запуск приложения в headless-режиме (python run.py --no-gui)
::   3. Юнит-тесты (pytest tests/ -q)
::
:: Использование:
::   cd ozon_fbs_label_app
::   smoke_test.bat
:: =============================================================================

echo.
echo ============================================================
echo   Smoke Test — OzonFbsLabelPrinter
echo   Предварительная проверка перед сборкой EXE
echo ============================================================
echo.

set ERRORS=0
set PYTHON=python

:: Если есть venv — использовать его
if exist ".venv\Scripts\python.exe" (
    set PYTHON=.venv\Scripts\python.exe
    echo [INFO] Используется виртуальное окружение .venv
) else (
    echo [INFO] Виртуальное окружение не найдено, используется системный Python
)

:: ---------------------------------------------------------------------------
:: Шаг 1: Проверка Python
:: ---------------------------------------------------------------------------
echo.
echo [1/3] Проверка синтаксиса Python-файлов (compileall) ...

%PYTHON% -m compileall app run.py -q
if errorlevel 1 (
    echo [ОШИБКА] Найдены синтаксические ошибки в Python-файлах!
    set /a ERRORS+=1
) else (
    echo [OK] Синтаксических ошибок не найдено.
)

:: ---------------------------------------------------------------------------
:: Шаг 2: Headless-запуск приложения
:: ---------------------------------------------------------------------------
echo.
echo [2/3] Запуск приложения в headless-режиме (--no-gui) ...
echo       (Проверяем импорты, mock-данные, генерацию PDF)
echo.

%PYTHON% run.py --no-gui
if errorlevel 1 (
    echo.
    echo [ОШИБКА] Headless-запуск завершился с ошибкой!
    echo          Проверьте что установлены все зависимости:
    echo            pip install -r requirements.txt
    set /a ERRORS+=1
) else (
    echo.
    echo [OK] Headless-запуск успешен.
)

:: ---------------------------------------------------------------------------
:: Шаг 3: Юнит-тесты
:: ---------------------------------------------------------------------------
echo.
echo [3/3] Запуск юнит-тестов (pytest tests/ -q) ...
echo.

:: Проверяем наличие pytest
%PYTHON% -m pytest --version >nul 2>&1
if errorlevel 1 (
    echo [ПРЕДУПРЕЖДЕНИЕ] pytest не установлен, пропускаем тесты.
    echo                  Установите: pip install pytest
    goto :results
)

%PYTHON% -m pytest tests/ -q --tb=short 2>&1
if errorlevel 1 (
    echo.
    echo [ОШИБКА] Часть тестов завершилась с ошибкой!
    set /a ERRORS+=1
) else (
    echo.
    echo [OK] Все тесты прошли успешно.
)

:: ---------------------------------------------------------------------------
:: Итог
:: ---------------------------------------------------------------------------
:results
echo.
echo ============================================================
if !ERRORS! EQU 0 (
    echo   ВСЕ ПРОВЕРКИ ПРОЙДЕНЫ — можно запускать build_exe.bat
) else (
    echo   НАЙДЕНЫ ОШИБКИ: !ERRORS! проверок завершились неудачно.
    echo   Исправьте ошибки перед запуском сборки.
)
echo ============================================================
echo.

pause
exit /b !ERRORS!
endlocal
