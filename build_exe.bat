@echo off
chcp 65001 >nul 2>&1
setlocal enabledelayedexpansion

:: =============================================================================
:: build_exe.bat — сборка OzonFbsLabelPrinter.exe для Windows
::
:: Использование:
::   Дважды щёлкните по файлу, или в командной строке:
::   cd ozon_fbs_label_app
::   build_exe.bat
::
:: Результат:
::   dist\OzonFbsLabelPrinter\OzonFbsLabelPrinter.exe
:: =============================================================================

echo.
echo ============================================================
echo   Сборка OzonFbsLabelPrinter.exe
echo   Ozon FBS Label — печать этикеток для FBS-отправлений
echo ============================================================
echo.

:: ---------------------------------------------------------------------------
:: Проверка Python
:: ---------------------------------------------------------------------------
python --version >nul 2>&1
if errorlevel 1 (
    echo [ОШИБКА] Python не найден.
    echo          Скачайте и установите Python 3.11+ с https://python.org/
    echo          При установке отметьте "Add Python to PATH"
    pause
    exit /b 1
)

for /f "tokens=2" %%v in ('python --version 2^>^&1') do set PYVER=%%v
echo [OK] Python %PYVER%

:: ---------------------------------------------------------------------------
:: Создание виртуального окружения
:: ---------------------------------------------------------------------------
if not exist ".venv\" (
    echo.
    echo [1/5] Создание виртуального окружения .venv ...
    python -m venv .venv
    if errorlevel 1 (
        echo [ОШИБКА] Не удалось создать venv.
        pause
        exit /b 1
    )
    echo [OK] Виртуальное окружение создано.
) else (
    echo [OK] Виртуальное окружение уже существует, используем его.
)

:: ---------------------------------------------------------------------------
:: Активация venv
:: ---------------------------------------------------------------------------
call .venv\Scripts\activate.bat
if errorlevel 1 (
    echo [ОШИБКА] Не удалось активировать виртуальное окружение.
    pause
    exit /b 1
)
echo [OK] Виртуальное окружение активировано.

:: ---------------------------------------------------------------------------
:: Обновление pip
:: ---------------------------------------------------------------------------
echo.
echo [2/5] Обновление pip ...
python -m pip install --upgrade pip --quiet
if errorlevel 1 (
    echo [ПРЕДУПРЕЖДЕНИЕ] Не удалось обновить pip, продолжаем...
)
echo [OK] pip обновлён.

:: ---------------------------------------------------------------------------
:: Установка зависимостей проекта
:: ---------------------------------------------------------------------------
echo.
echo [3/5] Установка зависимостей из requirements.txt ...
pip install -r requirements.txt --quiet
if errorlevel 1 (
    echo [ОШИБКА] Ошибка при установке зависимостей из requirements.txt
    echo          Проверьте подключение к интернету и попробуйте снова.
    pause
    exit /b 1
)
echo [OK] Зависимости проекта установлены.

:: ---------------------------------------------------------------------------
:: Установка PyInstaller и pywin32
:: ---------------------------------------------------------------------------
echo.
echo [4/5] Установка PyInstaller и pywin32 ...
pip install pyinstaller pywin32 --quiet
if errorlevel 1 (
    echo [ОШИБКА] Не удалось установить PyInstaller или pywin32.
    pause
    exit /b 1
)
echo [OK] PyInstaller и pywin32 установлены.

:: ---------------------------------------------------------------------------
:: Сборка EXE
:: ---------------------------------------------------------------------------
echo.
echo [5/5] Сборка приложения через PyInstaller ...
echo       Это может занять 1-3 минуты, пожалуйста подождите...
echo.

pyinstaller --clean --noconfirm OzonFbsLabelPrinter.spec
if errorlevel 1 (
    echo.
    echo [ОШИБКА] Сборка завершилась с ошибкой.
    echo.
    echo   Возможные причины:
    echo   1. Антивирус блокирует PyInstaller. Добавьте папку проекта в исключения.
    echo   2. Недостаточно прав. Запустите командную строку от имени администратора.
    echo   3. Конфликт зависимостей. Удалите папку .venv и запустите сборку снова.
    echo.
    echo   Подробный лог сборки смотрите в папке build\OzonFbsLabelPrinter\
    echo.
    pause
    exit /b 1
)

:: ---------------------------------------------------------------------------
:: Проверка результата
:: ---------------------------------------------------------------------------
set EXE_PATH=dist\OzonFbsLabelPrinter\OzonFbsLabelPrinter.exe

if exist "%EXE_PATH%" (
    echo.
    echo ============================================================
    echo   СБОРКА УСПЕШНА!
    echo.
    echo   Исполняемый файл:
    echo   %CD%\%EXE_PATH%
    echo.
    echo   Папка с приложением:
    echo   %CD%\dist\OzonFbsLabelPrinter\
    echo.
    echo   Для запуска: дважды щёлкните по OzonFbsLabelPrinter.exe
    echo   или скопируйте всю папку dist\OzonFbsLabelPrinter\ куда угодно.
    echo ============================================================
    echo.

    :: Открыть папку с результатом в Проводнике
    explorer dist\OzonFbsLabelPrinter
) else (
    echo.
    echo [ОШИБКА] EXE-файл не найден после сборки: %EXE_PATH%
    echo          Проверьте лог выше на наличие ошибок.
    echo.
    pause
    exit /b 1
)

pause
endlocal
